VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# 生产（Vercel）：设为 true，Moonshot Key 只放在服务端 MOONSHOT_API_KEY，并配置下方 Stripe / Supabase service role
# VITE_MOONSHOT_USE_PROXY=true
# 本地直连 Moonshot（未启用代理时必填）
VITE_MOONSHOT_API_KEY=sk-xxx
# 可选；默认 kimi-k2.5
# VITE_MOONSHOT_MODEL=kimi-k2.5
# Todo 正文 Tab 补全专用（默认 kimi-k2-turbo-preview）
# VITE_MOONSHOT_INLINE_MODEL=kimi-k2-turbo-preview
# Supabase（可选）：配置后与 Clerk JWT 模板 `supabase` 联动，/app 工作区会同步到云端
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# Agent 工具（联网搜索 / 抓取 / Skill 导入）：需部署 Edge Function `agent-tools`，并在 Supabase Secrets 中设置：
#   supabase secrets set BRAVE_API_KEY=你的_Brave_Search_API_密钥
# Clerk 登录时前端带的是 Clerk 签名的 JWT，Edge 用 JWKS 校验，须白名单签发方（与 JWT 里 iss 完全一致）：
#   supabase secrets set CLERK_JWT_ISSUER=https://你的实例.clerk.accounts.dev
# （在 Clerk Dashboard → API Keys → 「Frontend API」URL，开发环境多为 *.clerk.accounts.dev）
# 若 jwtVerify 报 audience 相关错误，再设：supabase secrets set CLERK_JWT_AUDIENCE=你在 JWT 模板里配置的 aud
# 抓取页优先使用免费 Jina Reader（r.jina.ai），失败则回退直连 HTML 去标签。
# 部署：supabase functions deploy agent-tools
#
# 生产站点根 URL（canonical、OG、sitemap 心智模型；本地可不设，将使用 window.location.origin）
# VITE_SITE_URL=https://todoagent.cc
#
# —— Vercel Serverless（勿用 VITE_ 前缀；在 Vercel → Environment Variables 配置）——
CLERK_SECRET_KEY=sk_live_xxx
MOONSHOT_API_KEY=sk-xxx
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...（仅服务端，勿提交）
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
SITE_URL=https://你的域名（Stripe 跳转 success/cancel）
# 开发时跳过计费逻辑（不设 Stripe 也可用代理调模型）
# SKIP_AGENT_BILLING=1
